# Brain config, Telegram tokens, and per-golem Spirit data all live in
# data/forge.json — edit them in the forge UI (uv run golem forge), not here.
# The data/ directory is therefore the only thing that MUST be persisted/backed up.

# Bind address for the forge UI (FastAPI/uvicorn).
# Inside Docker this must be 0.0.0.0 so the host port mapping can reach it.
# The Dockerfile already sets this; only override if you know why.
# FORGE_HOST=0.0.0.0

# Port the forge UI listens on inside the container.
# FORGE_PORT=8765

# Log level for the golem stack. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# GOLEM_LOG_LEVEL=INFO

# Notion integration token. Required only if any golem uses the `notion` skill.
# Create at https://www.notion.so/profile/integrations and share the target pages with it.
# NOTION_TOKEN=
