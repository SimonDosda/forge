# Brain (AI provider)
BRAIN_PROVIDER=mistral          # mistral | anthropic | openai | ollama
BRAIN_MODEL=mistral-small-latest
BRAIN_API_KEY=your_provider_api_key
BRAIN_BASE_URL=                 # optional override (e.g. http://localhost:11434 for ollama)

# Voice (Telegram)
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id              # the only chat allowed to talk to the bot

# Storage paths (relative to working directory)
MEMORY_ROOT=data/memory
SPIRIT_PATH=data/spirit.json
